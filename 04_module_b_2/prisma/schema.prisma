// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Company {
  id String @id @default(uuid(4)) @db.VarChar(36)
  name String @db.VarChar(50)
  address String?
  mobile String? @db.VarChar(12)
  email String @unique @db.VarChar(100)
  ownerId String @db.VarChar(36)
  Owner User @relation("owner", fields: [ownerId], references: [id])
  contactId String @db.VarChar(36)
  Contact User @relation("contact", fields: [contactId], references: [id])
  Products Products[]
  isDeactivated Boolean @default(false)
}

model User {
  id String @id @default(uuid(4)) @db.VarChar(36)
  name String @db.VarChar(50)
  mobile String? @db.VarChar(12)
  email String @unique @db.VarChar(100)
  ownedCompanies Company[] @relation("owner")
  contactCompanies Company[] @relation("contact")
}

model Products {
  GTIN BigInt @id
  name String @db.VarChar(50)
  nameFr String @db.VarChar(50)
  description String?
  descriptionFr String?
  brand String? @db.VarChar(20)
  country String? @db.VarChar(20)
  grossWeight Int? @db.SmallInt
  netWeight Int? @db.SmallInt
  unit String? @db.VarChar(10)
  image String?
  companyId String @db.VarChar(36)
  Company Company @relation(fields: [companyId], references: [id])
  isHidden Boolean @default(false)
  @@index([GTIN])
}