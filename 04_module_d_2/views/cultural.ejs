<script>
    const culturalBtn = document.querySelectorAll("input[name=btnradio]");
    let lastCulturalVal = 'cultural'
    culturalBtn.forEach(radio => {
        radio.addEventListener('change', (e) => {
            document.querySelector(`.${lastCulturalVal}`).style.display = 'none'
            document.querySelector(`.${e.target.id}`).style.display = 'block'
            lastCulturalVal = e.target.id
        })
    })
</script>