// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Region {
  id Int @id @default(autoincrement()) @db.SmallInt
  key String @db.VarChar(7) // max is 7 for central
  name String @db.VarChar(10)
  color String
  summary String?
  attractions Attraction[]
}

model Attraction {
  id Int @id @db.SmallInt @default(autoincrement())
  region_id Int @db.SmallInt
  region Region @relation(references: [id], fields: [region_id])
  name String @db.VarChar(100)
  description String?
}

model InfoItems {
  id Int @db.SmallInt @default(autoincrement()) @id
  category String? @db.VarChar(14)
  icon String?
  title String? @db.VarChar(50)
  body String?
  @@map("Info_items")
}

model Submission {
  id String @id @default(uuid(4)) @db.VarChar(36)
  name String? @db.VarChar(80)
  email String? @db.VarChar(100)
  country String? @db.VarChar(20)
  interests String?
  message String?
  submitted_at DateTime @default(now())
}